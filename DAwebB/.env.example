# --- Database (Azure Cosmos DB for MongoDB or standalone MongoDB) ---
# Prefer AZURE_COSMOS_MONGO_URI for Cosmos (mongodb+srv://…mongocluster.cosmos.azure.com/… per extension-repo tooling).
# URL-encode special characters in the password (e.g. @ → %40). If unset, MONGO_URI is used.
# AZURE_COSMOS_MONGO_URI=
MONGO_URI=mongodb://127.0.0.1:27017
# Logical DB name (e.g. IDAI_Web_Database on Cosmos, or test with local Node backend)
MONGO_DB_NAME=test
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_HOURS=72
# Optional: token lifetime in minutes (overrides JWT_EXPIRES_HOURS when set), e.g. 720 = 12h
# JWT_EXP_MINUTES=720

# Comma-separated browser origins for credentialed API calls (local Vite + production dashboard)
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://your-app.vercel.app

FLASK_DEBUG=1

# Set to true only if you want public signup when users already exist (e.g. staging).
# Leave false in production — add accounts as a logged-in C-Suite user instead.
OPEN_REGISTRATION=false

# --- Azure Blob (private screenshots; API signs read SAS at GET /api/screenshots/<id>/sas-url) ---
# Same signing as: generate_blob_sas(..., permission=read, expiry=now+AZURE_SAS_EXPIRY_MINUTES).
# Account name must match the host in screenshot_url (e.g. hpaientdevdatablob.blob.core.windows.net).
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
# If documents only have file_path (no full URL), blob is read from this container:
AZURE_SCREENSHOT_CONTAINER=screenshots
# SAS lifetime in minutes (default 60; max 1440). Use 2–15 for quick tests.
AZURE_SAS_EXPIRY_MINUTES=60
# Optional: CLI to paste a full blob URL and print SAS (from DAwebB folder):
#   python scripts/generate_blob_sas.py "https://<account>.blob.core.windows.net/<container>/<path>"
